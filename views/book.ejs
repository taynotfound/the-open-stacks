    19|  <meta name="theme-color" content="#c8392b">
    20|  <link rel="icon" href="/logo.svg" type="image/svg+xml">
    21|  <link rel="preconnect" href="https://fonts.googleapis.com">
    22|  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
    23|  <link rel="stylesheet" href="https://kit-pro.fontawesome.com/releases/v7.0.0/css/pro.min.css">
    24|  <link rel="stylesheet" href="/style.css">
    25|</head>
    26|<body>
    27|<nav class="nav">
    28|  <a href="/" class="nav-logo">
    29|    <img src="/logo.svg" alt="The Open Stacks">
    30|    The Open Stacks
    31|    <span class="nav-logo-sub">by Kommando 161</span>
