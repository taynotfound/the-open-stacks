   154|<% if (related && related.length > 0) { %>
   155|<section class="related-section container">
   156|  <div class="related-hd"><span class="related-label">Related</span></div>
   157|  <div class="related-grid">
   158|    <% related.forEach(r => { %>
   159|    <a href="/book/<%= r.slug %>" class="related-card">
   160|      <% if (r.cover) { %><img src="<%= r.cover %>" alt="" loading="lazy"><% } else { %><div class="related-placeholder"><%= (r.title||'?')[0].toUpperCase() %></div><% } %>
   161|      <span><%= r.title %></span>
   162|    </a>
   163|    <% }) %>
   164|  </div>
   165|</section>
