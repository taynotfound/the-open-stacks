<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <% if (book) { %>
  <title><%= book.title %> — The Open Stacks</title>
  <meta name="description" content="<%= (book.desc || ('Read ' + book.title + (book.author && book.author!=='Unknown' ? ' by ' + book.author : '') + ' — free access on The Open Stacks.')).slice(0,160) %>">
  <meta property="og:title" content="<%= book.title %>">
  <meta property="og:description" content="<%= (book.desc || '').slice(0, 160) %>">
  <% if (book.cover) { %><meta property="og:image" content="<%= book.cover %>"><% } else { %><meta property="og:image" content="https://theopenstacks.apolochees.me/logo.svg"><% } %>
  <meta property="og:type" content="book">
  <% if (book.author && book.author !== 'Unknown') { %><meta name="author" content="<%= book.author %>"><% } %>
  <% if (book.tags && book.tags.length) { %><meta name="keywords" content="<%= book.tags.concat([book.category,'anarchism','radical','political']).filter(Boolean).join(', ') %>"><% } %>
  <link rel="canonical" href="https://theopenstacks.apolochees.me/book/<%= book.slug %>">
  <script type="application/ld+json"><%- JSON.stringify({
    "@context":"https://schema.org",
    "@type": book.category==='audio' ? "AudioObject" : book.category==='video' ? "VideoObject" : "Book",
    "name": book.title,
    "author": book.author && book.author!=='Unknown' ? {"@type":"Person","name":book.author} : undefined,
    "description": (book.desc||'').slice(0,500) || undefined,
    "url": "https://theopenstacks.apolochees.me/book/"+book.slug,
    "image": book.cover || undefined,
    "keywords": book.tags ? book.tags.join(', ') : undefined,
    "inLanguage": book.language || "en",
    "isAccessibleForFree": true,
    "publisher": {"@type":"Organization","name":"The Open Stacks","url":"https://theopenstacks.apolochees.me"}
  }, null, 0) %></script>
  <link rel="alternate" hreflang="<%= book.language || 'en' %>" href="https://theopenstacks.apolochees.me/book/<%= book.slug %>">
  <link rel="alternate" hreflang="x-default" href="https://theopenstacks.apolochees.me/book/<%= book.slug %>">
  <% if (translations && translations.length) { translations.forEach(t => { %><link rel="alternate" hreflang="<%= t.language || 'en' %>" href="https://theopenstacks.apolochees.me/book/<%= t.slug %>"><% }) } %>
  <% } else { %>
  <title>Not Found — The Open Stacks</title>
  <% } %>
  <meta name="theme-color" content="#c8392b">
  <link rel="icon" href="/logo.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://kit-pro.fontawesome.com/releases/v7.0.0/css/pro.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<%- include('_nav', { showSearch: false }) %>
<div id="read-progress"></div>

<% if (book && book.cover) { %>
<div class="book-cover-hero">
  <img src="<%= book.cover %>" alt="">
  <div class="hero-overlay"></div>
</div>
<% } %>

<main class="book-page">
  <div class="book-page-inner">
    <a href="/" class="back-link">← Library</a>

    <% if (error && !book) { %>
      <div class="error-banner"><%= error %></div>
    <% } else if (book) { %>

    <article>
      <header class="book-header">
        <% if (book.category) { %><a href="/category/<%= book.category %>" class="category-label"><%= book.category %></a><% } %>
        <h1 class="book-title"><%= book.title %></h1>
        <% if (book.author && book.author !== 'Unknown') { %><div class="book-author">by <%= book.author %></div><% } %>
        <div class="book-meta-row">
          <% if (book.sourceName) { %><a href="/source/<%= encodeURIComponent(book.sourceName) %>" class="meta-pill"><%= book.sourceName %></a><% } %>
          <% if (book.language && book.language !== 'en') { %><span class="meta-pill"><%= book.language %></span><% } %>
          <% if (book.added) { %><span class="meta-date"><%= new Date(book.added * 1000).getFullYear() %></span><% } %>
          <% if (book.hasBody) { %><span class="meta-pill pill-text">Full text</span><% } %>
          <% if (book.translatedFrom && book.translatedFrom.trim()) { %><span class="meta-pill pill-trans">Translated from <%= book.translatedFrom %><% if (book.translatedType) { %> · <%= book.translatedType %><% } %></span><% } %>
        </div>
      </header>

      <% if (book.translatedFrom && book.translatedFrom.trim() && book.originalSlug) { %>
      <div class="tx-origin-bar">
        <span>Translated to English from <strong><%= book.translatedFrom %></strong><% if (book.translatedType) { %> via <strong><%= book.translatedType %></strong><% } %></span>
        <a href="/book/<%= book.originalSlug %>" class="tx-origin-link">← View original</a>
      </div>
      <% } %>

      <% 
        const ISO3={eng:'en',fra:'fr',spa:'es',deu:'de',ita:'it',por:'pt',rus:'ru',pol:'pl',ell:'el',bul:'bg',cmn:'zh',jpn:'ja',nld:'nl',ces:'cs',ind:'id',tur:'tr',ukr:'uk',swe:'sv',nor:'no',fin:'fi',kat:'ka',hye:'hy'};
        const langCode=l=>ISO3[l]||l;
        const allSiblings = [...(cwcSiblings||[]), ...(translations||[])];
      %>
      <% if (allSiblings.length > 0) { %>
      <div class="lang-switcher">
        <span>Also in:</span>
        <span class="lang-pill current"><%= langCode(book.language||'en') %></span>
        <% allSiblings.forEach(t => { %>
          <a href="/book/<%= t.slug %>" class="lang-pill translated"><%= langCode(t.language||'?') %></a>
        <% }) %>
      </div>
      <% } %>

      <% if (book.desc) { %><div class="book-desc"><%= book.desc %></div><% } %>
      <div class="book-actions">
        <button class="btn-save" id="saveBtn" data-slug="<%= book.slug %>" data-title="<%= book.title.replace(/"/g,'&quot;') %>">☆ Save</button>
        <button class="btn-share" id="shareBtn">↗ Share</button>
        <button class="btn-share" id="shortcutsBtn" title="Keyboard shortcuts">⌨ ?</button>
      </div>
      <p class="shortcuts-hint"><kbd>j</kbd>/<kbd>k</kbd> scroll · <kbd>t</kbd> translate · <kbd>b</kbd> bookmark · <kbd>?</kbd> all shortcuts</p>
      <% if (book.tags && book.tags.length > 0) { %>
      <div class="book-tags">
        <% book.tags.forEach(t => { %><span class="tag"><%= t.replace(/-/g, ' ') %></span><% }) %>
      </div>
      <% } %>

      <section class="related-section" style="display:none">
        <h3>Related texts</h3>
        <div class="related-grid" id="relatedGrid"></div>
      </section>

      <% if (book.files && book.files.length > 0) { %>
      <%
        const AUDIO_EXT = /\.(mp3|ogg|aac|flac|opus)$/i;
        const VIDEO_EXT = /\.(mp4|ogv|webm)$/i;
        const AUDIO_MIME = {mp3:'audio/mpeg',ogg:'audio/ogg',aac:'audio/aac',flac:'audio/flac',opus:'audio/ogg'};
        const VIDEO_MIME = {mp4:'video/mp4',ogv:'video/ogg',webm:'video/webm'};
        // group audio tracks by base name, prefer mp3
        const trackMap = {};
        // group video by base name, prefer mp4
        const videoMap = {};
        book.files.forEach(f => {
          const url = typeof f==='string'?f:(f.url||f);
          const name = (f.name||url.split('/').pop());
          const ext = (name.split('.').pop()||'').toLowerCase();
          const base = name.replace(/\.[^.]+$/, '');
          if (AUDIO_EXT.test(name)) {
            if (!trackMap[base] || ext==='mp3') trackMap[base] = { url, name, ext };
          } else if (VIDEO_EXT.test(name)) {
            if (!videoMap[base] || ext==='mp4') videoMap[base] = { url, name, ext };
          }
        });
        const tracks = Object.values(trackMap);
        const videos = Object.values(videoMap);
        const nonMedia = book.files.filter(f => {
          const n = (f.name||(f.url||f).split('/').pop());
          return !AUDIO_EXT.test(n) && !VIDEO_EXT.test(n);
        });
      %>
      <% if (videos.length) { %>
      <div class="book-player">
        <span class="section-label">Watch</span>
        <% videos.forEach(v => { %>
        <div style="margin-top:.5rem">
          <% if (videos.length > 1) { %><small style="color:var(--muted);display:block;margin-bottom:.2rem"><%= v.name %></small><% } %>
          <video controls preload="none" style="width:100%;border-radius:6px;background:#000">
            <source src="<%= v.url %>" type="<%= VIDEO_MIME[v.ext]||'video/mp4' %>">
          </video>
        </div>
        <% }) %>
      </div>
      <% } %>
      <% if (tracks.length) { %>
      <div class="book-player">
        <span class="section-label">Listen</span>
        <% tracks.forEach(t => { %>
        <div style="margin-top:.5rem">
          <% if (tracks.length > 1) { %><small style="color:var(--muted);display:block;margin-bottom:.2rem"><%= t.name %></small><% } %>
          <audio controls preload="none" style="width:100%">
            <source src="<%= t.url %>" type="<%= AUDIO_MIME[t.ext]||'audio/mpeg' %>">
          </audio>
        </div>
        <% }) %>
      </div>
      <% } %>
      <% if (nonMedia.length) { %>
      <div class="book-downloads">
        <span class="section-label">Files</span>
        <div class="download-row">
          <% nonMedia.forEach(f => { const url=typeof f==='string'?f:(f.url||f); const name=f.name||url.split('/').pop(); const ext=(name.split('?')[0].split('.').pop()||'FILE').toUpperCase(); %>
            <a href="<%= url %>" target="_blank" rel="noopener" class="btn-download" title="<%= name %>"><%= ext %></a>
          <% }) %>
        </div>

      </div>
      <% } %>
      <% } %>

      <% if (body && !allSiblings.length && book.language && book.language !== 'en' && book.language !== 'eng') { %>
      <div class="body-divider"></div>

      <div style="margin-bottom:1rem;display:flex;align-items:center;gap:0;">
        <button class="tx-btn" id="txBtn" data-lang="<%= book.language || 'auto' %>">⟳ Translate</button>
        <select class="tx-select" id="txSrc">
          <option value="deepl">DeepL (best)</option>
          <option value="mymemory">MyMemory (free)</option>
          <option value="google">Google Translate ⚠</option>
        </select>
      </div>
      <div class="tx-status" id="txStatus"></div>

      <div class="book-with-toc">
        <% if (toc && toc.length > 1) { %>
        <aside class="toc" id="toc">
          <div class="toc-title">Contents</div>
          <ol>
            <% toc.forEach((h, i) => { %><li><a href="#section-<%= i %>"><%= h %></a></li><% }) %>
          </ol>
        </aside>
        <% } %>

        <div class="book-content-col">
          <% if (book.cover) { %>
          <div class="book-cover-hero">
            <img src="<%= book.cover %>" alt="Cover of <%= book.title %>" loading="lazy">
          </div>
          <% } %>
          <div id="tx-content">
            <div class="body-text" id="bodyText"><%- body %></div>
          </div>
        </div>
      </div>

      <% } %>
    </article>
    <% } %>
  </div>
</main>

<% if (related && related.length > 0) { %>
<section class="related-section container">
  <div class="related-hd"><span class="related-label">You might also like</span></div>
  <div class="related-grid">
    <% related.forEach(r => { %>
    <a href="/book/<%= r.slug %>" class="related-card">
      <% if (r.cover) { %><img src="<%= r.cover %>" alt="" loading="lazy"><% } else { %><div class="related-placeholder"><%= (r.title||'?')[0].toUpperCase() %></div><% } %>
      <span><%= r.title %></span>
    </a>
    <% }) %>
  </div>
</section>
<% } %>

<%- include('_footer', { stats }) %>

<!-- Share dialog -->
<dialog id="share-dlg" onclick="if(event.target===this)this.close()">
  <div style="background:var(--surface);border:1px solid var(--border);border-radius:8px;padding:1.5rem;min-width:300px;max-width:460px">
    <p style="margin:0 0 .75rem;font-weight:600">Share</p>
    <div style="display:flex;gap:.5rem">
      <input id="share-url-input" readonly style="flex:1;background:var(--bg);border:1px solid var(--border);border-radius:4px;padding:.4rem .6rem;color:var(--text);font-size:.85rem">
      <button id="share-copy-btn" class="btn-download">Copy link</button>
    </div>
    <button onclick="this.closest('dialog').close()" style="margin-top:.75rem;background:none;border:none;color:var(--muted);cursor:pointer;font-size:.8rem">Close</button>
  </div>
</dialog>

<!-- Gallery lightbox -->
<dialog id="gallery-dlg" onclick="this.close()">
  <img id="gallery-img" src="" alt="">
</dialog>

<!-- Floating TOC (populated by JS) -->
<nav class="book-toc" id="bookToc"></nav>

<!-- Quote bar -->
<div id="quote-bar"><button id="quoteCopy">❝ Copy quote</button><button id="quoteClose">✕</button></div>

<!-- Shortcuts modal -->
<div id="shortcuts-modal">
  <div id="shortcuts-inner">
    <button class="shortcuts-close" id="shortcutsCloseBtn">✕</button>
    <h3>Keyboard Shortcuts</h3>
    <table>
      <tr><td>j / ↓</td><td>Scroll down</td></tr>
      <tr><td>k / ↑</td><td>Scroll up</td></tr>
      <tr><td>t</td><td>Translate</td></tr>
      <tr><td>b</td><td>Bookmark / save</td></tr>
      <tr><td>s</td><td>Share</td></tr>
      <tr><td>?</td><td>This panel</td></tr>
      <tr><td>Esc</td><td>Close panel</td></tr>
    </table>
  </div>
</div>

<% if (book) { %>
<script>
const BOOK_SLUG = '<%= book.slug %>';
const BOOK_TITLE = '<%= (book.title||'').replace(/'/g, "\\'") %>';

// ── Gallery ──
const dlg = document.getElementById('gallery-dlg');
const gImg = document.getElementById('gallery-img');
document.querySelectorAll('.gallery-link').forEach(a => {
  a.addEventListener('click', e => { e.preventDefault(); gImg.src=a.href; dlg.showModal(); });
});

// ── Reading progress ──
const prog = document.getElementById('read-progress');
if (prog) {
  window.addEventListener('scroll', () => {
    const h = document.documentElement;
    const pct = h.scrollTop / (h.scrollHeight - h.clientHeight) * 100;
    prog.style.width = Math.min(100, pct) + '%';
  }, { passive: true });
}

// ── TOC ──
const tocEl = document.getElementById('bookToc');
const headings = [...document.querySelectorAll('.body-text h2, .body-text h3')];
if (tocEl && headings.length > 2) {
  tocEl.innerHTML = headings.map(h =>
    `<a href="#${h.id}" data-id="${h.id}">${h.tagName==='H3'?'&nbsp;&nbsp;':''}${h.textContent.trim()}</a>`
  ).join('');
  const tocLinks = [...tocEl.querySelectorAll('a')];
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        tocLinks.forEach(a => a.classList.toggle('active', a.dataset.id === e.target.id));
      }
    });
  }, { rootMargin: '-20% 0px -70% 0px' });
  headings.forEach(h => obs.observe(h));
}

// ── Quote bar ──
const qBar = document.getElementById('quote-bar');
const qCopy = document.getElementById('quoteCopy');
const qClose = document.getElementById('quoteClose');
document.addEventListener('mouseup', () => {
  const sel = window.getSelection();
  if (!sel || sel.isCollapsed || !sel.toString().trim()) { qBar.style.display='none'; return; }
  const r = sel.getRangeAt(0).getBoundingClientRect();
  qBar.style.cssText = `display:flex;top:${r.top + window.scrollY - 40}px;left:${r.left + r.width/2 - 60}px`;
});
qCopy.addEventListener('click', () => {
  const text = window.getSelection().toString().trim();
  navigator.clipboard.writeText(`> ${text}\n\n— ${BOOK_TITLE} (theopenstacks.apolochees.me/book/${BOOK_SLUG})`);
  qCopy.textContent = '✓ Copied!'; setTimeout(() => { qCopy.textContent='❝ Copy quote'; qBar.style.display='none'; }, 1500);
});
qClose.addEventListener('click', () => qBar.style.display='none');

// ── Share ──
const shareUrl = window.location.href;
document.getElementById('shareBtn')?.addEventListener('click', () => {
  const dlg = document.getElementById('share-dlg');
  document.getElementById('share-url-input').value = shareUrl;
  dlg.showModal();
});
document.getElementById('share-copy-btn')?.addEventListener('click', () => {
  navigator.clipboard.writeText(shareUrl);
  const btn = document.getElementById('share-copy-btn');
  btn.textContent = '✓ Copied!'; setTimeout(() => btn.textContent = 'Copy link', 1500);
});

// ── Shortcuts modal ──
const modal = document.getElementById('shortcuts-modal');
document.getElementById('shortcutsBtn')?.addEventListener('click', () => modal.classList.add('open'));
document.getElementById('shortcutsCloseBtn')?.addEventListener('click', () => modal.classList.remove('open'));
modal.addEventListener('click', e => { if(e.target===modal) modal.classList.remove('open'); });

// ── Keyboard shortcuts ──
document.addEventListener('keydown', e => {
  if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA' || e.target.isContentEditable) return;
  if (e.key === '?' || e.key === '/') { e.preventDefault(); modal.classList.toggle('open'); }
  else if (e.key === 'Escape') modal.classList.remove('open');
  else if (e.key === 'j' || e.key === 'ArrowDown') window.scrollBy({top:200,behavior:'smooth'});
  else if (e.key === 'k' || e.key === 'ArrowUp') window.scrollBy({top:-200,behavior:'smooth'});
  else if (e.key === 't') document.getElementById('txBtn')?.click();
  else if (e.key === 'b') document.getElementById('saveBtn')?.click();
  else if (e.key === 's') document.getElementById('shareBtn')?.click();
});

// ── Related texts ──
fetch(`/api/related/${BOOK_SLUG}`).then(r=>r.json()).then(items => {
  if (!items.length) return;
  const el = document.getElementById('relatedGrid');
  if (!el) return;
  el.innerHTML = items.map(it => `
    <a href="/book/${it.slug}" class="related-card">
      <div class="related-card-img">${it.cover ? `<img src="${it.cover}" alt="" loading="lazy">` : `<div style="height:100%;background:var(--surface)"></div>`}</div>
      <div class="related-card-body">
        <div class="related-card-title">${it.title}</div>
        <div class="related-card-cat">${it.category||''}</div>
      </div>
    </a>`).join('');
  el.closest('.related-section').style.display = 'block';
}).catch(()=>{});
</script>
<% } %>
<script>
// Theme toggle

<% if (body) { %>
const BOOK_LANG = '<%= book.language %>';
const TX_CACHE_KEY = 'os_tx_<%= book.slug %>';
const txBtn = document.getElementById('txBtn');
const txSrc = document.getElementById('txSrc');
const txStatus = document.getElementById('txStatus');
const bodyText = document.getElementById('bodyText');
let originalHTML = bodyText.innerHTML, translated = false;

txBtn.addEventListener('click', async () => {
  if (translated) {
    bodyText.innerHTML = originalHTML;
    txBtn.textContent = '⟳ Translate to English';
    txStatus.textContent = '';
    translated = false;
    return;
  }
  const engine = txSrc.value;
  if (engine === 'google') {
    if (!confirm('Send text to Google Translate? Google may log and use this data.')) return;
    if (!confirm('Are you sure? Your text will be sent to Google\'s servers.')) return;
  }
  const cached = localStorage.getItem(TX_CACHE_KEY + '_' + engine);
  if (cached) {
    bodyText.innerHTML = cached;
    txBtn.textContent = '✕ Original';
    txStatus.innerHTML = 'from cache — <button onclick="localStorage.removeItem(\''+TX_CACHE_KEY+'_'+engine+'\');txStatus.textContent=\'cleared\'" style="background:none;border:none;color:var(--accent);cursor:pointer;text-decoration:underline;font-size:0.82rem;padding:0">clear</button>';
    translated = true; return;
  }

  txBtn.disabled = true; txBtn.textContent = 'Translating…';
  const txAbort = new AbortController();
  const onUnload = () => txAbort.abort();
  window.addEventListener('beforeunload', onUnload);
  const text = bodyText.innerText;
  const paras = text.split(/\n{2,}/);
  const chunks = []; let cur = '';
  for (const p of paras) { if (cur.length + p.length > 3500 && cur) { chunks.push(cur.trim()); cur = ''; } cur += (cur?'\n\n':'')+p; }
  if (cur.trim()) chunks.push(cur.trim());

  const parts = [];
  for (let i=0; i<chunks.length; i++) {
    txStatus.textContent = `Chunk ${i+1}/${chunks.length}…`;
    try {
      const url = `/api/translate/${engine}`;
      const body = { text: chunks[i], sourceLang: BOOK_LANG };
      const r = await fetch(url, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body),signal:txAbort.signal});
      const d = await r.json();
      parts.push(d.translated || `[error: ${d.error}]`);
    } catch(e) { parts.push(`[error: ${e.message}]`); }
  }

  const html = parts.join('\n\n').split('\n\n').map(p=>`<p>${p.replace(/\n/g,'<br>')}</p>`).join('\n');
  localStorage.setItem(TX_CACHE_KEY+'_'+engine, html);
  bodyText.innerHTML = html;
  window.removeEventListener('beforeunload', onUnload);
  txBtn.disabled = false; txBtn.textContent = '✕ Original';
  txStatus.innerHTML = `via ${engine==='google'?'Google':'MyMemory'} — <button id="contribTx" class="tx-contribute-btn">contribute this translation →</button>`;
  translated = true;

  document.getElementById('contribTx').addEventListener('click', async () => {
    const btn = document.getElementById('contribTx');
    btn.textContent = 'Submitting…'; btn.disabled = true;
    const plainText = parts.join('\n\n');
    try {
      const r = await fetch('/api/translate/contribute', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ slug: '<%= book.slug %>', category: '<%= book.category %>', title: '<%= (book.title||"").replace(/'/g, "\\'") %>', targetLang: 'en', translatedText: plainText })
      });
      const d = await r.json();
      if (d.error) throw new Error(d.error);
      btn.outerHTML = `<a href="${d.pr}" target="_blank" rel="noopener" class="tx-contribute-btn">✓ PR opened →</a>`;
    } catch(e) { btn.textContent = `✕ ${e.message}`; btn.disabled = false; }
  });
});
<% } %>
</script>
</body>
</html>
