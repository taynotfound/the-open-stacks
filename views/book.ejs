<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <% if (book) { %>
  <title><%= book.title %> — The Open Stacks</title>
  <meta name="description" content="<%= (book.desc || ('Read ' + book.title + (book.author ? ' by ' + book.author : '') + ' — free access on The Open Stacks.')).slice(0,160) %>">
  <meta property="og:title" content="<%= book.title %>">
  <meta property="og:description" content="<%= (book.desc||'').slice(0,160) %>">
  <% if (book.cover) { %><meta property="og:image" content="<%= book.cover %>"><% } else { %><meta property="og:image" content="/logo.svg"><% } %>
  <meta property="og:type" content="article">
  <meta name="author" content="<%= book.author || '' %>">
  <% if (book.tags && book.tags.length) { %><meta name="keywords" content="<%= book.tags.concat([book.category,'anarchism','radical','political']).filter(Boolean).join(', ') %>"><% } %>
  <link rel="canonical" href="https://theopenstacks.apolochees.me/book/<%= book.slug %>">
  <% } else { %>
  <title>Not Found — The Open Stacks</title>
  <% } %>
  <meta name="theme-color" content="#c8392b">
  <link rel="icon" href="/logo.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://kit-pro.fontawesome.com/releases/v7.0.0/css/pro.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<nav class="nav">
  <a href="/" class="nav-logo">
    <img src="/logo.svg" alt="The Open Stacks">
    The Open Stacks
    <span class="nav-logo-sub">by Kommando 161</span>
  </a>
  <div class="nav-right">
    <button id="themeToggle" class="theme-toggle" title="Toggle light mode">☀</button>
    <%= stats.total ? stats.total.toLocaleString() : '—' %> texts
  </div>
</nav>

<main class="book-page">
  <div class="book-page-inner">
    <a href="/" class="back-link">← Library</a>

    <% if (error && !book) { %>
      <div class="error-banner"><%= error %></div>
    <% } else if (book) { %>

    <article>
      <header class="book-header">
        <% if (book.category) { %><a href="/?category=<%= book.category %>" class="category-label"><%= book.category %></a><% } %>
        <h1 class="book-title"><%= book.title %></h1>
        <% if (book.author && book.author !== 'Unknown') { %><div class="book-author">by <%= book.author %></div><% } %>
        <div class="book-meta-row">
          <% if (book.sourceName) { %><a href="/?source=<%= encodeURIComponent(book.sourceName) %>" class="meta-pill"><%= book.sourceName %></a><% } %>
          <% if (book.language && book.language !== 'en') { %><span class="meta-pill"><%= book.language %></span><% } %>
          <% if (book.added) { %><span class="meta-date"><%= new Date(book.added * 1000).getFullYear() %></span><% } %>
          <% if (book.hasBody) { %><span class="meta-pill pill-text">Full text</span><% } %>
          <% if (book.translatedFrom && book.translatedFrom.trim()) { %><span class="meta-pill pill-trans">Translated from <%= book.translatedFrom %><% if (book.translatedType) { %> · <%= book.translatedType %><% } %></span><% } %>
        </div>
      </header>

      <% if (book.translatedFrom && book.translatedFrom.trim() && book.originalSlug) { %>
      <div class="tx-origin-bar">
        <span>Translated to English from <strong><%= book.translatedFrom %></strong><% if (book.translatedType) { %> via <strong><%= book.translatedType %></strong><% } %></span>
        <a href="/book/<%= book.originalSlug %>" class="tx-origin-link">← View original</a>
      </div>
      <% } %>

      <% if (book.translations && book.translations.length > 0) { %>
      <div class="lang-switcher">
        <span>Also in:</span>
        <span class="lang-pill current">English (original)</span>
        <% book.translations.forEach(t => { %>
          <a href="/book/<%= t.slug %>" class="lang-pill translated"><%= t.language %> <span class="lang-engine"><%= t.translatedType || 'translated' %></span></a>
        <% }) %>
      </div>
      <% } %>

      <% if (book.desc) { %><div class="book-desc"><%= book.desc %></div><% } %>
      <div class="book-actions">
        <button class="btn-save" id="saveBtn" data-slug="<%= book.slug %>" data-title="<%= book.title.replace(/"/g,'&quot;') %>">☆ Save</button>
      </div>
      <% if (book.tags && book.tags.length > 0) { %>
      <div class="book-tags">
        <% book.tags.forEach(t => { %><span class="tag"><%= t.replace(/-/g, ' ') %></span><% }) %>
      </div>
      <% } %>

      <% if (book.files && book.files.length > 0) { %>
      <%
        const AUDIO_EXT = /\.(mp3|ogg|aac|flac|opus)$/i;
        const MIME = {mp3:'audio/mpeg',ogg:'audio/ogg',aac:'audio/aac',flac:'audio/flac',opus:'audio/ogg'};
        // group by base name → pick best format per track (prefer mp3)
        const trackMap = {};
        book.files.forEach(f => {
          const url = typeof f==='string'?f:(f.url||f);
          const name = (f.name||url.split('/').pop());
          const ext = (name.split('.').pop()||'').toLowerCase();
          if (!AUDIO_EXT.test(name)) return;
          const base = name.replace(/\.[^.]+$/, '');
          if (!trackMap[base] || ext==='mp3') trackMap[base] = { url, name, ext };
        });
        const tracks = Object.values(trackMap);
        const nonAudio = book.files.filter(f => { const u=typeof f==='string'?f:(f.url||f); return !AUDIO_EXT.test((f.name||u.split('/').pop())); });
      %>
      <% if (tracks.length) { %>
      <div class="book-player">
        <span class="section-label">Listen</span>
        <% tracks.forEach(t => { %>
        <div style="margin-top:.5rem">
          <% if (tracks.length > 1) { %><small style="color:var(--muted);display:block;margin-bottom:.2rem"><%= t.name %></small><% } %>
          <audio controls preload="none" style="width:100%">
            <source src="<%= t.url %>" type="<%= MIME[t.ext]||'audio/mpeg' %>">
          </audio>
        </div>
        <% }) %>
      </div>
      <% } %>
      <% if (nonAudio.length) { %>
      <div class="book-downloads">
        <span class="section-label">Files</span>
        <div class="download-row">
          <% nonAudio.forEach(f => { const url=typeof f==='string'?f:(f.url||f); const name=f.name||url.split('/').pop(); const ext=(url.split('?')[0].split('.').pop()||'FILE').toUpperCase(); %>
            <a href="<%= url %>" target="_blank" rel="noopener" class="btn-download" title="<%= name %>"><%= ext %></a>
          <% }) %>
        </div>
      </div>
      <% } %>
      <% } %>

      <% if (body) { %>
      <div class="body-divider"></div>

      <% if (book.language && book.language !== 'en') { %>
      <div style="margin-bottom:1rem;display:flex;align-items:center;gap:0;">
        <button class="tx-btn" id="txBtn" data-lang="<%= book.language %>">⟳ Translate to English</button>
        <select class="tx-select" id="txSrc">
          <option value="mymemory">MyMemory (free)</option>
          <option value="google">Google Translate</option>
        </select>
      </div>
      <div class="tx-status" id="txStatus"></div>
      <% } %>

      <div class="book-with-toc">
        <% if (toc && toc.length > 1) { %>
        <aside class="toc" id="toc">
          <div class="toc-title">Contents</div>
          <ol>
            <% toc.forEach((h, i) => { %><li><a href="#section-<%= i %>"><%= h %></a></li><% }) %>
          </ol>
        </aside>
        <% } %>

        <div class="book-content-col">
          <% if (book.cover) { %>
          <div class="book-cover-hero">
            <img src="<%= book.cover %>" alt="Cover of <%= book.title %>" loading="lazy">
          </div>
          <% } %>
          <div id="tx-content">
            <div class="body-text" id="bodyText"><%- body %></div>
          </div>
        </div>
      </div>

      <% } else if (book.hasBody) { %>
        <div class="body-loading">Loading full text…</div>
      <% } %>
    </article>
    <% } %>
  </div>
</main>

<% if (related && related.length > 0) { %>
<section class="related-section container">
  <div class="related-hd"><span class="related-label">You might also like</span></div>
  <div class="related-grid">
    <% related.forEach(r => { %>
    <a href="/book/<%= r.slug %>" class="related-card">
      <% if (r.cover) { %><img src="<%= r.cover %>" alt="" loading="lazy"><% } else { %><div class="related-placeholder"><%= (r.title||'?')[0].toUpperCase() %></div><% } %>
      <span><%= r.title %></span>
    </a>
    <% }) %>
  </div>
</section>
<% } %>

<%- include('_footer', { stats }) %>

<script>
// Theme toggle
const toggle = document.getElementById('themeToggle');
if (toggle) {
  const apply = t => { document.documentElement.dataset.theme = t; localStorage.theme = t; toggle.textContent = t === 'light' ? '☾' : '☀'; };
  apply(localStorage.theme === 'light' ? 'light' : 'dark');
  toggle.addEventListener('click', () => apply(document.documentElement.dataset.theme === 'light' ? 'dark' : 'light'));
}

<% if (body && book.language && book.language !== 'en') { %>
const BOOK_LANG = '<%= book.language %>';
const TX_CACHE_KEY = 'os_tx_<%= book.slug %>';
const txBtn = document.getElementById('txBtn');
const txSrc = document.getElementById('txSrc');
const txStatus = document.getElementById('txStatus');
const bodyText = document.getElementById('bodyText');
let originalHTML = bodyText.innerHTML, translated = false;

txBtn.addEventListener('click', async () => {
  if (translated) {
    bodyText.innerHTML = originalHTML;
    txBtn.textContent = '⟳ Translate to English';
    txStatus.textContent = '';
    translated = false;
    return;
  }
  const engine = txSrc.value;
  const cached = localStorage.getItem(TX_CACHE_KEY + '_' + engine);
  if (cached) {
    bodyText.innerHTML = cached;
    txBtn.textContent = '✕ Original';
    txStatus.innerHTML = 'from cache — <button onclick="localStorage.removeItem(\''+TX_CACHE_KEY+'_'+engine+'\');txStatus.textContent=\'cleared\'" style="background:none;border:none;color:var(--accent);cursor:pointer;text-decoration:underline;font-size:0.82rem;padding:0">clear</button>';
    translated = true; return;
  }

  txBtn.disabled = true; txBtn.textContent = 'Translating…';
  const text = bodyText.innerText;
  const paras = text.split(/\n{2,}/);
  const chunks = []; let cur = '';
  for (const p of paras) { if (cur.length + p.length > 3500 && cur) { chunks.push(cur.trim()); cur = ''; } cur += (cur?'\n\n':'')+p; }
  if (cur.trim()) chunks.push(cur.trim());

  const parts = [];
  for (let i=0; i<chunks.length; i++) {
    txStatus.textContent = `Chunk ${i+1}/${chunks.length}…`;
    try {
      const url = engine==='google' ? '/api/translate' : '/api/translate/mymemory';
      const body = engine==='google' ? {q:chunks[i],source:BOOK_LANG,target:'en'} : {text:chunks[i],sourceLang:BOOK_LANG};
      const r = await fetch(url, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
      const d = await r.json();
      parts.push(d.translated || `[error: ${d.error}]`);
    } catch(e) { parts.push(`[error: ${e.message}]`); }
  }

  const html = parts.join('\n\n').split('\n\n').map(p=>`<p>${p.replace(/\n/g,'<br>')}</p>`).join('\n');
  localStorage.setItem(TX_CACHE_KEY+'_'+engine, html);
  bodyText.innerHTML = html;
  txBtn.disabled = false; txBtn.textContent = '✕ Original';
  txStatus.innerHTML = `via ${engine==='google'?'Google':'MyMemory'} — <button id="contribTx" class="tx-contribute-btn">contribute this translation →</button>`;
  translated = true;

  document.getElementById('contribTx').addEventListener('click', async () => {
    const btn = document.getElementById('contribTx');
    btn.textContent = 'Submitting…'; btn.disabled = true;
    const plainText = parts.join('\n\n');
    try {
      const r = await fetch('/api/translate/contribute', {
        method:'POST', headers:{'Content-Type':'application/json'},
        body: JSON.stringify({ slug: '<%= book.slug %>', category: '<%= book.category %>', title: '<%= (book.title||"").replace(/'/g, "\\'") %>', targetLang: 'en', translatedText: plainText })
      });
      const d = await r.json();
      if (d.error) throw new Error(d.error);
      btn.outerHTML = `<a href="${d.pr}" target="_blank" rel="noopener" class="tx-contribute-btn">✓ PR opened →</a>`;
    } catch(e) { btn.textContent = `✕ ${e.message}`; btn.disabled = false; }
  });
});
<% } %>
</script>
</body>
</html>
