    39|<main class="book-page">
    40|  <div class="book-page-inner">
    41|    <a href="/" class="back-link">← Library</a>
    42|
    43|    <% if (error && !book) { %>
    44|      <div class="error-banner"><%= error %></div>
    45|    <% } else if (book) { %>
    46|
    47|    <article>
    48|      <header class="book-header">
    49|        <% if (book.category) { %><span class="category-label"><%= book.category %></span><% } %>
    50|        <h1 class="book-title"><%= book.title %></h1>
    51|        <% if (book.author) { %><div class="book-author">by <%= book.author %></div><% } %>
    52|        <div class="book-meta-row">
    53|          <% if (book.sourceName) { %><span class="meta-pill"><%= book.sourceName %></span><% } %>
    54|          <% if (book.language && book.language !== 'en') { %><span class="meta-pill"><%= book.language %></span><% } %>
    55|          <% if (book.added) { %><span class="meta-date"><%= new Date(book.added * 1000).getFullYear() %></span><% } %>
    56|          <% if (book.hasBody) { %><span class="meta-pill pill-text">Full text</span><% } %>
    57|          <% if (book.translatedFrom && book.translatedFrom.trim()) { %><span class="meta-pill pill-trans">Translated from <%= book.translatedFrom %><% if (book.translatedType) { %> · <%= book.translatedType %><% } %></span><% } %>
    58|        </div>
    59|      </header>
    60|
    61|      <% if (book.translatedFrom && book.translatedFrom.trim() && book.originalSlug) { %>
    62|      <div class="tx-origin-bar">
    63|        <span>Translated to English from <strong><%= book.translatedFrom %></strong><% if (book.translatedType) { %> via <strong><%= book.translatedType %></strong><% } %></span>
    64|        <a href="/book/<%= book.originalSlug %>" class="tx-origin-link">← View original</a>
    65|      </div>
    66|      <% } %>
    67|
    68|      <% if (book.translations && book.translations.length > 0) { %>
    69|      <div class="lang-switcher">
    70|        <span>Also in:</span>
    71|        <span class="lang-pill current">English (original)</span>
    72|        <% book.translations.forEach(t => { %>
    73|          <a href="/book/<%= t.slug %>" class="lang-pill translated"><%= t.language %> <span class="lang-engine"><%= t.translatedType || 'translated' %></span></a>
    74|        <% }) %>
    75|      </div>
    76|      <% } %>
    77|
    78|      <% if (book.desc) { %><div class="book-desc"><%= book.desc %></div><% } %>
    79|      <div class="book-actions">
    80|        <button class="btn-save" id="saveBtn" data-slug="<%= book.slug %>" data-title="<%= book.title.replace(/"/g,'&quot;') %>">☆ Save</button>
    81|      </div>
    82|      <% if (book.tags && book.tags.length > 0) { %>
    83|      <div class="book-tags">
    84|        <% book.tags.forEach(t => { %><span class="tag"><%= t.replace(/-/g, ' ') %></span><% }) %>
    85|      </div>
    86|      <% } %>
    87|
    88|      <% if (book.files && book.files.length > 0) { %>
    89|      <% const audioFile = book.files.find(f => { const u=typeof f==='string'?f:(f.url||f); return /\.(mp3|ogg|aac|flac|opus)$/i.test(u.split('?')[0]); }); %>
    90|      <% if (audioFile) { const audioUrl = typeof audioFile==='string'?audioFile:(audioFile.url||audioFile); %>
    91|      <div class="book-player">
    92|        <span class="section-label">Listen</span>
    93|        <audio controls preload="none" style="width:100%;margin-top:.5rem">
    94|          <source src="<%= audioUrl %>" type="audio/mpeg">
    95|        </audio>
    96|      </div>
    97|      <% } %>
    98|      <div class="book-downloads">
    99|        <span class="section-label">Files</span>
   100|        <div class="download-row">
   101|          <% book.files.forEach(f => { const url = typeof f==='string'?f:(f.url||f); const name = f.name || url.split('/').pop(); const ext=(url.split('?')[0].split('.').pop()||'FILE').toUpperCase(); %>
   102|            <a href="<%= url %>" target="_blank" rel="noopener" class="btn-download" title="<%= name %>"><%= ext %></a>
   103|          <% }) %>
   104|        </div>
   105|      </div>
   106|      <% } %>
   107|
   108|      <% if (body) { %>
   109|      <div class="body-divider"></div>
   110|
   111|      <% if (book.language && book.language !== 'en') { %>
   112|      <div style="margin-bottom:1rem;display:flex;align-items:center;gap:0;">
   113|        <button class="tx-btn" id="txBtn" data-lang="<%= book.language %>">⟳ Translate to English</button>
   114|        <select class="tx-select" id="txSrc">
   115|          <option value="mymemory">MyMemory (free)</option>
   116|          <option value="google">Google Translate</option>
   117|        </select>
   118|      </div>
   119|      <div class="tx-status" id="txStatus"></div>
   120|      <% } %>
   121|
   122|      <div class="book-with-toc">
   123|        <% if (toc && toc.length > 1) { %>
   124|        <aside class="toc" id="toc">
   125|          <div class="toc-title">Contents</div>
   126|          <ol>
   127|            <% toc.forEach((h, i) => { %><li><a href="#section-<%= i %>"><%= h %></a></li><% }) %>
   128|          </ol>
   129|        </aside>
   130|        <% } %>
   131|
   132|        <div class="book-content-col">
   133|          <% if (book.cover) { %>
   134|          <div class="book-cover-hero">
   135|            <img src="<%= book.cover %>" alt="Cover of <%= book.title %>" loading="lazy">
   136|          </div>
   137|          <% } %>
   138|          <div id="tx-content">
   139|            <div class="body-text" id="bodyText"><%- body %></div>
   140|          </div>
   141|        </div>
   142|      </div>
   143|
   144|      <% } else if (book.hasBody) { %>
   145|        <div class="body-loading">Loading full text…</div>
   146|      <% } %>
   147|    </article>
   148|    <% } %>
   149|  </div>
   150|</main>
   151|
   152|<%- include('_footer', { stats }) %>
