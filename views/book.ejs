   168|<script>
   169|// Theme toggle
   170|const toggle = document.getElementById('themeToggle');
   171|if (toggle) {
   172|  const apply = t => { document.documentElement.dataset.theme = t; localStorage.theme = t; toggle.textContent = t === 'light' ? '☾' : '☀'; };
   173|  apply(localStorage.theme === 'light' ? 'light' : 'dark');
   174|  toggle.addEventListener('click', () => apply(document.documentElement.dataset.theme === 'light' ? 'dark' : 'light'));
   175|}
   176|
   177|<% if (body && book.language && book.language !== 'en') { %>
   178|const BOOK_LANG = '<%= book.language %>';
   179|const TX_CACHE_KEY = 'os_tx_<%= book.slug %>';
   180|const txBtn = document.getElementById('txBtn');
   181|const txSrc = document.getElementById('txSrc');
   182|const txStatus = document.getElementById('txStatus');
   183|const bodyText = document.getElementById('bodyText');
   184|let originalHTML = bodyText.innerHTML, translated = false;
   185|
   186|txBtn.addEventListener('click', async () => {
   187|  if (translated) {
   188|    bodyText.innerHTML = originalHTML;
   189|    txBtn.textContent = '⟳ Translate to English';
   190|    txStatus.textContent = '';
   191|    translated = false;
   192|    return;
   193|  }
   194|  const engine = txSrc.value;
   195|  const cached = localStorage.getItem(TX_CACHE_KEY + '_' + engine);
   196|  if (cached) {
   197|    bodyText.innerHTML = cached;
   198|    txBtn.textContent = '✕ Original';
   199|    txStatus.innerHTML = 'from cache — <button onclick="localStorage.removeItem(\''+TX_CACHE_KEY+'_'+engine+'\');txStatus.textContent=\'cleared\'" style="background:none;border:none;color:var(--accent);cursor:pointer;text-decoration:underline;font-size:0.82rem;padding:0">clear</button>';
   200|    translated = true; return;
   201|  }
   202|
   203|  txBtn.disabled = true; txBtn.textContent = 'Translating…';
   204|  const text = bodyText.innerText;
   205|  const paras = text.split(/\n{2,}/);
   206|  const chunks = []; let cur = '';
   207|  for (const p of paras) { if (cur.length + p.length > 3500 && cur) { chunks.push(cur.trim()); cur = ''; } cur += (cur?'\n\n':'')+p; }
   208|  if (cur.trim()) chunks.push(cur.trim());
   209|
   210|  const parts = [];
   211|  for (let i=0; i<chunks.length; i++) {
   212|    txStatus.textContent = `Chunk ${i+1}/${chunks.length}…`;
   213|    try {
   214|      const url = engine==='google' ? '/api/translate' : '/api/translate/mymemory';
   215|      const body = engine==='google' ? {q:chunks[i],source:BOOK_LANG,target:'en'} : {text:chunks[i],sourceLang:BOOK_LANG};
   216|      const r = await fetch(url, {method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(body)});
   217|      const d = await r.json();
   218|      parts.push(d.translated || `[error: ${d.error}]`);
   219|    } catch(e) { parts.push(`[error: ${e.message}]`); }
   220|  }
   221|
   222|  const html = parts.join('\n\n').split('\n\n').map(p=>`<p>${p.replace(/\n/g,'<br>')}</p>`).join('\n');
   223|  localStorage.setItem(TX_CACHE_KEY+'_'+engine, html);
   224|  bodyText.innerHTML = html;
   225|  txBtn.disabled = false; txBtn.textContent = '✕ Original';
   226|  txStatus.innerHTML = `via ${engine==='google'?'Google':'MyMemory'} — <button id="contribTx" class="tx-contribute-btn">contribute this translation →</button>`;
   227|  translated = true;
   228|
   229|  document.getElementById('contribTx').addEventListener('click', async () => {
   230|    const btn = document.getElementById('contribTx');
   231|    btn.textContent = 'Submitting…'; btn.disabled = true;
   232|    const plainText = parts.join('\n\n');
   233|    try {
   234|      const r = await fetch('/api/translate/contribute', {
   235|        method:'POST', headers:{'Content-Type':'application/json'},
   236|        body: JSON.stringify({ slug: '<%= book.slug %>', category: '<%= book.category %>', title: '<%= (book.title||"").replace(/'/g, "\\'") %>', targetLang: 'en', translatedText: plainText })
   237|      });
   238|      const d = await r.json();
   239|      if (d.error) throw new Error(d.error);
   240|      btn.outerHTML = `<a href="${d.pr}" target="_blank" rel="noopener" class="tx-contribute-btn">✓ PR opened →</a>`;
   241|    } catch(e) { btn.textContent = `✕ ${e.message}`; btn.disabled = false; }
   242|  });
   243|});
   244|<% } %>
   245|</script>
   246|</body>
   247|</html>
