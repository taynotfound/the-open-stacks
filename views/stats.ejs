<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Stats · The Open Stacks</title>
  <meta name="description" content="Library statistics for The Open Stacks · texts by category, full-text coverage, sources.">
  <meta name="theme-color" content="#c8392b">
  <link rel="icon" href="/logo.svg" type="image/svg+xml">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://kit-pro.fontawesome.com/releases/v7.0.0/css/pro.min.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<nav class="nav">
  <a href="/" class="nav-logo">
    <img src="/logo.svg" alt="The Open Stacks">
    The Open Stacks
    <span class="nav-logo-sub">by Kommando 161</span>
  </a>
  <div class="nav-right">
    <button id="themeToggle" class="theme-toggle" title="Toggle light mode">☀</button>
  </div>
</nav>
<script>
const _t=localStorage.theme==='light'?'light':'dark';
document.documentElement.dataset.theme=_t;
document.getElementById('themeToggle').textContent=_t==='light'?'☾':'☀';
document.getElementById('themeToggle').addEventListener('click',()=>{const n=document.documentElement.dataset.theme==='light'?'dark':'light';document.documentElement.dataset.theme=n;localStorage.theme=n;document.getElementById('themeToggle').textContent=n==='light'?'☾':'☀';});
</script>

<main class="page-inner">
  <div class="page-header">
    <h1>Library Stats</h1>
    <p class="page-subtitle">A living archive. Numbers update as comrades contribute.</p>
  </div>

  <div class="stat-hero-grid">
    <div class="stat-hero-card">
      <span class="stat-hero-num"><%= stats.total ? stats.total.toLocaleString() : '—' %></span>
      <span class="stat-hero-label">Texts indexed</span>
    </div>
    <div class="stat-hero-card red">
      <span class="stat-hero-num"><%= stats.withBody ? stats.withBody.toLocaleString() : '—' %></span>
      <span class="stat-hero-label">With full text</span>
    </div>
    <div class="stat-hero-card">
      <span class="stat-hero-num"><%= stats.total && stats.withBody ? Math.round(stats.withBody/stats.total*100) : '—' %>%</span>
      <span class="stat-hero-label">Full-text coverage</span>
    </div>
    <div class="stat-hero-card">
      <span class="stat-hero-num"><%= stats.sources || '—' %></span>
      <span class="stat-hero-label">Source collections</span>
    </div>
    <div class="stat-hero-card">
      <span class="stat-hero-num"><%= stats.categories || breakdown.length || '—' %></span>
      <span class="stat-hero-label">Categories</span>
    </div>
    <div class="stat-hero-card">
      <span class="stat-hero-num"><%= stats.atRisk ? stats.atRisk.toLocaleString() : '—' %></span>
      <span class="stat-hero-label">At-risk texts</span>
    </div>
  </div>

  <% if (breakdown.length > 0) { %>
  <section class="stats-section">
    <h2>Texts by Category</h2>
    <div class="breakdown-table">
      <div class="breakdown-header">
        <span>Category</span><span>Texts</span><span>Full text</span><span>Coverage</span>
      </div>
      <% const max = breakdown[0].count; %>
      <% breakdown.forEach(row => { %>
      <div class="breakdown-row">
        <span><a href="/?category=<%= row._id %>"><%= row._id || 'uncategorised' %></a></span>
        <span><%= row.count.toLocaleString() %></span>
        <span><%= row.withBody.toLocaleString() %></span>
        <span class="breakdown-bar-cell">
          <span class="breakdown-bar" style="width:<%= Math.round(row.withBody/row.count*100) %>%"></span>
          <span class="breakdown-pct"><%= Math.round(row.withBody/row.count*100) %>%</span>
        </span>
      </div>
      <% }) %>
    </div>
  </section>
  <% } %>

  <section class="stats-section">
    <h2>What we preserve</h2>
    <div class="prose">
      <p>Every text in this archive is here because it matters · to workers, to revolutionaries, to anyone who's ever been told the wrong people don't deserve access to knowledge. We don't paywall theory. We don't demand accounts. We don't track you.</p>
      <p>The archive grows through <a href="/contribute">community contributions</a>. If you have a text that belongs here · a pamphlet, a zine, an essay that only exists on a dying website · <strong>add it</strong>. We will review it and merge it.</p>
    </div>
  </section>
</main>

<%- include('_footer', { stats }) %>
</body>
</html>
