<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= status %> · The Open Stacks</title>
  <meta name="robots" content="noindex">
  <meta name="theme-color" content="#c8392b">
  <link rel="icon" href="/logo.svg" type="image/svg+xml">
  
  <link rel="stylesheet" href="/fonts/fonts.css">
  <link rel="stylesheet" href="/style.css">
</head>
<body>
<%- include('_nav') %>
<main class="container" style="min-height:65vh;display:flex;align-items:center;justify-content:center;">
  <div style="text-align:center;padding:4rem 1rem;max-width:480px">
    <div style="font-size:6rem;font-weight:700;color:var(--border2);line-height:1;font-family:'Crimson Pro',serif;letter-spacing:-2px"><%= status %></div>
    <h1 style="margin:1rem 0 0.5rem;font-size:1.4rem;color:var(--text);font-weight:600"><%= title %></h1>
    <p style="color:var(--muted);margin-bottom:2rem;line-height:1.6"><%= message %></p>
    <div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap">
      <a href="/" class="btn-primary">← Back to Library</a>
      <a href="/random" class="btn-secondary">Random Item</a>
    </div>
  </div>
</main>
<%- include('_footer', { stats: stats || {} }) %>
<script src="/app.js"></script>
</body>
</html>
