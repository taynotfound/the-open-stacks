<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%
    const _title = q ? `"${q}" — The Open Stacks`
      : category ? `${category.replace(/-/g,' ')} — The Open Stacks`
      : source   ? `${source} — The Open Stacks`
      : 'The Open Stacks — Free Radical Library';
    const _desc = q ? `Search results for "${q}" in the Open Stacks radical library.`
      : category ? `Browse ${category.replace(/-/g,' ')} texts — free radical library with ${stats.total ? stats.total.toLocaleString() + ' items' : 'thousands of items'}.`
      : source   ? `All texts from ${source} — archived on The Open Stacks.`
      : `A free, open-access archive of anarchist, anti-fascist, and radical political texts. ${stats.total ? stats.total.toLocaleString() + ' items' : ''} — no account, no tracking.`;
    const _canonical = canonical || `https://theopenstacks.apolochees.me${req.path}${Object.keys(req.query).length ? '?'+new URLSearchParams(req.query).toString() : ''}`;
  %>
  <title><%= _title %></title>
  <meta name="description" content="<%= _desc %>">
  <meta property="og:title" content="<%= _title %>">
  <meta property="og:description" content="<%= _desc %>">
  <meta property="og:image" content="https://theopenstacks.apolochees.me/logo.svg">
  <meta property="og:type" content="website">
  <meta name="robots" content="<%= (q||page>1) ? 'noindex,follow' : 'index,follow' %>">
  <meta name="theme-color" content="#c8392b">
  <link rel="icon" href="/logo.svg" type="image/svg+xml">
  <link rel="canonical" href="<%= _canonical %>">
  <link rel="alternate" hreflang="x-default" href="<%= _canonical %>">
  <% langs.forEach(l => { %><link rel="alternate" hreflang="<%= l.code %>" href="<%= _canonical + (_canonical.includes('?') ? '&' : '?') + 'lang=' + l.code %>"><% }) %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://kit-pro.fontawesome.com/releases/v7.0.0/css/pro.min.css">
  <link rel="stylesheet" href="/style.css">
  <link rel="alternate" type="application/rss+xml" title="The Open Stacks" href="/feed.xml">
</head>
<body>
<nav class="nav">
  <a href="/" class="nav-logo">
    <img src="/logo.svg" alt="">
    The Open Stacks
    <span class="nav-logo-sub">by Kommando 161</span>
  </a>
  <div class="nav-search">
    <div class="search-wrap">
      <input type="text" id="search-input" placeholder="Search texts, authors, topics…" value="<%= q %>" autocomplete="off" spellcheck="false">
      <div id="search-suggest" class="search-suggest"></div>
    </div>
  </div>
  <div class="nav-right">
    <button id="themeToggle" class="theme-toggle" title="Toggle light mode">☀</button>
  </div>
</nav>
<script>
const t=localStorage.theme==='light'?'light':'dark';
document.documentElement.dataset.theme=t;
document.getElementById('themeToggle').textContent=t==='light'?'☾':'☀';
document.getElementById('themeToggle').addEventListener('click',()=>{const n=document.documentElement.dataset.theme==='light'?'dark':'light';document.documentElement.dataset.theme=n;localStorage.theme=n;document.getElementById('themeToggle').textContent=n==='light'?'☾':'☀';});
</script>

<% if (!q && !category && !source && page <= 1) { %>
<div class="hero-banner">
  <div class="hero-top">
    <div class="hero-logo">
      <img src="/logo.svg" alt="">
      <div>
        <h1 class="hero-title">The Open Stacks</h1>
        <p class="hero-tagline">host what they'd erase</p>
      </div>
    </div>
    <div class="hero-stats">
      <div class="hstat">
        <span class="hstat-n" id="liveTotal"><%= stats.total ? stats.total.toLocaleString() : '—' %></span>
        <span class="hstat-l">texts <span id="liveArrow" class="live-arrow"></span></span>
      </div>
      <div class="hstat-sep"></div>
      <div class="hstat"><span class="hstat-n"><%= stats.sources || '—' %></span><span class="hstat-l">sources</span></div>
      <div class="hstat-sep"></div>
      <div class="hstat"><span class="hstat-n">free</span><span class="hstat-l">always</span></div>
    </div>
  </div>
  <p class="hero-creed-short">A community-run radical archive. No account. No tracking. <strong>Read it. Share it. Organize.</strong></p>
</div>

<section class="newswire-section">
  <div class="newswire-inner container">
    <div class="newswire-hd">
      <span class="newswire-label">Newswire</span>
      <a href="https://anarchistnews.org" target="_blank" rel="noopener" class="newswire-src">anarchistnews.org ↗</a>
      <a href="https://de.indymedia.org/newswire" target="_blank" rel="noopener" class="newswire-src">de.indymedia.org ↗</a>
    </div>
    <div class="newswire-cards" id="newswireFeed"><span class="newswire-loading">Loading…</span></div>
    <div class="newswire-dots" id="newswireDots"></div>
  </div>
</section>
<script>
(function(){
  const PAGE=3;
  let items=[], cur=0, timer=null;
  const el=document.getElementById('newswireFeed');
  const dots=document.getElementById('newswireDots');

  function srcColor(src){ return src==='anarchistnews.org' ? '#c8392b' : '#4a7c59'; }

  function render(){
    const slice=items.slice(cur, cur+PAGE);
    el.innerHTML=slice.map(it=>`
      <a href="${it.url}" target="_blank" rel="noopener" class="nw-card">
        <div class="nw-card-src" style="background:${srcColor(it.src)}">${it.src}</div>
        <div class="nw-card-title">${it.lang&&it.lang!=='en'?`<span class="nw-lang">${it.lang}</span> `:''}${it.title}</div>
      </a>`).join('');
    // dots
    const pages=Math.ceil(items.length/PAGE);
    dots.innerHTML=Array.from({length:pages},(_,i)=>
      `<button class="nw-dot${i===Math.floor(cur/PAGE)?' active':''}" onclick="nwGo(${i*PAGE})"></button>`).join('');
  }

  window.nwGo=function(idx){ cur=idx; render(); resetTimer(); };

  function next(){ cur=(cur+PAGE)%items.length; if(cur+PAGE>items.length) cur=0; render(); }
  function resetTimer(){ clearInterval(timer); timer=setInterval(next,5000); }

  fetch('/api/news').then(r=>r.json()).then(d=>{
    if(!d.length){el.innerHTML='<span class="newswire-empty">—</span>';return;}
    items=d; render(); resetTimer();
  }).catch(()=>{el.innerHTML='';});
})();
</script>
<% } %>


<div class="filter-bar-wrap">
<div class="filter-bar">
  <a href="/" class="pill<%= !category && !source ? ' active' : '' %>">All</a>
  <span class="pill-sep">·</span>
  <% categories.filter(c=>c!=='anarchism').forEach(cat => { %>
    <a href="/category/<%= encodeURIComponent(cat) %>"
       class="pill<%= category === cat ? ' active' : '' %>"><%= cat.replace(/-/g,' ') %></a>
  <% }) %>
</div>
</div>
<div class="filter-bar-wrap">
<div class="filter-bar filter-bar-secondary">
  <a href="/random" class="pill pill-random">⚄ Random</a>
  <% sources.forEach(s => { %>
  <a href="/source/<%= encodeURIComponent(s) %>" class="pill<%= source === s ? ' active' : '' %>"><%= s %></a>
  <% }) %>
</div>
</div>
<div class="filter-bar-wrap filter-bar-langs">
<div class="filter-bar filter-bar-secondary">
  <span class="pill-sep" style="font-size:0.7rem;opacity:.5;flex-shrink:0">🌐</span>
  <a href="/?<%= new URLSearchParams(Object.assign({}, q?{q}:{}, category?{category}:{}, source?{source}:{})).toString() %>" class="pill<%= !lang ? ' active' : '' %>">All</a>
  <% langs.forEach(l => { %>
  <a href="/?<%= new URLSearchParams(Object.assign({}, q?{q}:{}, category?{category}:{}, source?{source}:{}, {lang:l.code})).toString() %>"
     class="pill<%= lang===l.code ? ' active' : '' %>"><%= l.label %></a>
  <% }) %>
</div>
</div>

<% if (error) { %><div class="error-banner" style="margin:1rem 1.5rem"><%= error %></div><% } %>

<main class="container">
  <div class="results-meta">
    <% if (q) { %>Results for "<strong><%= q %></strong>" — <%= total.toLocaleString() %> found
    <% } else if (source) { %><strong><%= source %></strong> — <%= total.toLocaleString() %> items
    <% } else if (category) { %><strong><%= category %></strong> — <%= total.toLocaleString() %> items
    <% } else { %><%= total.toLocaleString() %> items in the collection<% } %>
  </div>

  <div class="book-grid">
    <% books.forEach(book => { %>
    <a href="/book/<%= book.slug %>" class="book-card">
      <div class="book-cover">
        <% if (book.cover) { %>
          <img src="<%= book.cover %>" alt="" loading="lazy">
        <% } else { %>
          <% const _ci = (book.title||'?').split('').reduce((a,c)=>a+c.charCodeAt(0),0) % 8; %>
          <div class="cover-placeholder cp-<%= _ci %>"><span class="cover-initial"><%= (book.title||'?')[0].toUpperCase() %></span></div>
        <% } %>
      </div>
      <div class="book-info">
        <div class="book-title-card"><%= book.title %></div>
        <% if (book.author && book.author !== 'Unknown') { %><div class="book-author-card"><%= book.author %></div><% } %>
        <% if (book._readMin > 1) { %><div class="book-readtime"><%= book._readMin %> min read</div><% } %>
        <div class="book-badges">
          <% if (book.category && book.category !== category) { %><span class="badge badge-cat"><%= book.category.replace(/-/g,' ') %></span><% } %>
          <% if (book.hasBody) { %><span class="badge badge-text">full text</span><% } %>
          <% if (book.sourceName && book.sourceName !== 'The Anarchist Library') { %><span class="badge badge-src"><%= book.sourceName %></span><% } %>
        </div>
      </div>
    </a>
    <% }) %>
  </div>

  <% if (pages > 1) { %>
  <div class="pagination">
    <% const _qs = (p) => '?page='+p+(q?'&q='+encodeURIComponent(q):'')+(category?'&category='+encodeURIComponent(category):'')+(source?'&source='+encodeURIComponent(source):'')+(lang?'&lang='+encodeURIComponent(lang):''); %>
    <% if (page > 1) { %><a href="<%= _qs(page-1) %>" class="btn">← Prev</a><% } %>
    <span class="page-info"><%= page %> / <%= pages %></span>
    <% if (page < pages) { %><a href="<%= _qs(page+1) %>" class="btn">Next →</a><% } %>
  </div>
  <% } %>
</main>

<%- include('_footer', { stats }) %>
<script src="/app.js"></script>
<script>
// live count + growth arrow
(function(){
  const el=document.getElementById('liveTotal');
  const arrow=document.getElementById('liveArrow');
  if(!el) return;
  const SK='tos_baseline_total';
  let baseline=parseInt(localStorage.getItem(SK)||'0');
  function update(){
    fetch('/api/stats').then(r=>r.json()).then(d=>{
      const n=d.total||0;
      if(el) el.textContent=n.toLocaleString();
      if(!baseline){ baseline=n; localStorage.setItem(SK,n); }
      if(arrow && n>baseline){
        const pct=Math.round((n-baseline)/baseline*100);
        arrow.textContent=pct>0?` ↑${pct}%`:'';
        arrow.className='live-arrow up';
      }
    }).catch(()=>{});
  }
  update();
  setInterval(update, 15000);
})();
</script>
<script>
document.querySelectorAll('.filter-bar-wrap').forEach(wrap => {
  const bar = wrap.querySelector('.filter-bar');
  if (!bar) return;
  function update() {
    const canScroll = bar.scrollWidth > bar.clientWidth + 4;
    const atEnd = bar.scrollLeft + bar.clientWidth >= bar.scrollWidth - 4;
    wrap.classList.toggle('can-scroll', canScroll);
    wrap.classList.toggle('at-end', atEnd);
  }
  update();
  bar.addEventListener('scroll', update, { passive: true });
  window.addEventListener('resize', update, { passive: true });
  // scroll on hover with mouse wheel redirect
  wrap.addEventListener('wheel', e => {
    if (Math.abs(e.deltaX) < Math.abs(e.deltaY)) {
      e.preventDefault();
      bar.scrollBy({ left: e.deltaY * 2, behavior: 'smooth' });
    }
  }, { passive: false });
});
</script>
</body>
</html>
