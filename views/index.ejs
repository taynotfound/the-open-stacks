<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <%
    const _title = q ? `"${q}" · The Open Stacks`
      : category ? `${category.replace(/-/g,' ')} · The Open Stacks`
      : source   ? `${source} · The Open Stacks`
      : 'The Open Stacks · Free Radical Library';
    const _desc = q ? `Search results for "${q}" in the Open Stacks radical library.`
      : category ? `Browse ${category.replace(/-/g,' ')} texts · free radical library.`
      : source   ? `All texts from ${source} · archived on The Open Stacks.`
      : `A free, open-access archive of anarchist, anti-fascist, and radical political texts. ${stats.total ? stats.total.toLocaleString() + ' items' : ''} · no account, no tracking.`;
    const _canonical = canonical || 'https://theopenstacks.apolochees.me/';
  %>
  <title><%= _title %></title>
  <meta name="description" content="<%= _desc %>">
  <meta property="og:title" content="<%= _title %>">
  <meta property="og:description" content="<%= _desc %>">
  <meta property="og:image" content="https://theopenstacks.apolochees.me/logo.svg">
  <meta property="og:type" content="website">
  <meta name="robots" content="<%= (q||page>1) ? 'noindex,follow' : 'index,follow' %>">
  <meta name="theme-color" content="#c8392b">
  <link rel="icon" href="/logo.svg" type="image/svg+xml">
  <link rel="canonical" href="<%= _canonical %>">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Crimson+Pro:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://kit-pro.fontawesome.com/releases/v7.0.0/css/pro.min.css">
  <link rel="stylesheet" href="/style.css">
  <link rel="alternate" type="application/rss+xml" title="The Open Stacks" href="/feed.xml">
</head>
<body>
<%- include('_nav', { q, showSearch: true }) %>

<% if (!q && !category && !source && page <= 1) { %>
<div class="ticker">
  <span class="ticker-label">Newswire</span>
  <div class="ticker-scroll" id="tickerScroll"></div>
</div>
<script>
fetch('/api/news').then(r=>r.json()).then(d=>{
  if(!d||!d.length) return;
  const el=document.getElementById('tickerScroll');
  el.innerHTML=d.slice(0,24).map(it=>`<a href="${it.url}" target="_blank" rel="noopener" class="ticker-link">${it.title}</a>`).join('<span class="ticker-divider">·</span>');
}).catch(()=>{});
</script>
<% } %>

<div class="toolbar">
  <div class="toolbar-pills" id="toolbarPills">
    <a href="/" class="tpill<%= !category && !source && !lang ? ' on' : '' %>">All</a>
    <% categories.filter(c=>c!=='anarchism').forEach(cat => { %>
    <a href="/category/<%= encodeURIComponent(cat) %>" class="tpill<%= category===cat?' on':'' %>"><%= cat.replace(/-/g,' ') %></a>
    <% }) %>
    <span class="tpill-divider">|</span>
    <% sources.forEach(s => { %>
    <a href="/source/<%= encodeURIComponent(s) %>" class="tpill tpill-src<%= source===s?' on':'' %>"><%= s %></a>
    <% }) %>
  </div>
  <div class="toolbar-end">
    <% if (langs.length > 0) { %>
    <select class="lang-sel" onchange="if(this.value)location.href=this.value">
      <option value="/?<%= new URLSearchParams(Object.assign({}, q?{q}:{}, category?{category}:{}, source?{source}:{})).toString() %>"<%= !lang?' selected':'' %>>Lang</option>
      <% langs.forEach(l => { %>
      <option value="/?<%= new URLSearchParams(Object.assign({}, q?{q}:{}, category?{category}:{}, source?{source}:{}, {lang:l.code})).toString() %>"<%= lang===l.code?' selected':'' %>><%= l.label %></option>
      <% }) %>
    </select>
    <% } %>
    <a href="/random" class="tpill tpill-rand" title="Random">⚄</a>
    <span class="toolbar-count" id="liveTotal"><%= stats.total ? stats.total.toLocaleString() : '' %></span>
  </div>
</div>

<% if (error) { %><div class="error-banner" style="margin:0.5rem 1rem"><%= error %></div><% } %>

<main class="container">
  <% if (q || source || category) { %>
  <div class="results-meta">
    <% if (q) { %>Results for "<strong><%= q %></strong>" · <%= total.toLocaleString() %> found
    <% } else if (source) { %><strong><%= source %></strong> · <%= total.toLocaleString() %>
    <% } else if (category) { %><strong><%= category %></strong> · <%= total.toLocaleString() %>
    <% } %>
  </div>
  <% } %>

  <div class="book-grid">
    <% books.forEach(book => { %>
    <a href="/book/<%= book.slug %>" class="book-card">
      <div class="book-cover">
        <% if (book.cover) { %>
          <img src="<%= book.cover %>" alt="" loading="lazy">
        <% } else { %>
          <% const _ci = (book.title||'?').split('').reduce((a,c)=>a+c.charCodeAt(0),0) % 8; %>
          <div class="cover-placeholder cp-<%= _ci %>"><span class="cover-initial"><%= (book.title||'?')[0].toUpperCase() %></span></div>
        <% } %>
        <% if (book.language && book.language !== 'eng' && book.language !== 'en') { %><span class="cover-lang"><%= book.language.toUpperCase() %></span><% } %>
      </div>
      <div class="book-info">
        <div class="book-title-card"><%= book.title %></div>
        <% if (book.author && book.author !== 'Unknown') { %><div class="book-author-card"><%= book.author %></div><% } %>
      </div>
    </a>
    <% }) %>
  </div>

  <% if (pages > 1) { %>
  <div class="pagination">
    <% const _qs = (p) => '?page='+p+(q?'&q='+encodeURIComponent(q):'')+(category?'&category='+encodeURIComponent(category):'')+(source?'&source='+encodeURIComponent(source):'')+(lang?'&lang='+encodeURIComponent(lang):''); %>
    <% if (page > 1) { %><a href="<%= _qs(page-1) %>" class="btn">← Prev</a><% } %>
    <span class="page-info"><%= page %> / <%= pages %></span>
    <% if (page < pages) { %><a href="<%= _qs(page+1) %>" class="btn">Next →</a><% } %>
  </div>
  <% } %>
</main>

<%- include('_footer', { stats }) %>
<script src="/app.js"></script>
<script>
(function(){
  const el=document.getElementById('liveTotal');
  if(!el) return;
  setInterval(()=>fetch('/api/stats').then(r=>r.json()).then(d=>{
    if(d.total&&d.total!==parseInt(el.textContent.replace(/,/g,'')))el.textContent=d.total.toLocaleString();
  }).catch(()=>{}), 20000);
})();
// toolbar scroll overflow indicator
const pills = document.getElementById('toolbarPills');
if (pills) {
  const update = () => pills.classList.toggle('scrollable', pills.scrollWidth > pills.clientWidth + 4);
  update();
  window.addEventListener('resize', update, {passive:true});
  pills.addEventListener('wheel', e => {
    if (Math.abs(e.deltaX) < Math.abs(e.deltaY)) { e.preventDefault(); pills.scrollBy({left: e.deltaY*2, behavior:'smooth'}); }
  }, {passive:false});
}
</script>
</body>
</html>
